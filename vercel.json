{
  "version": 2,
  "builds": [
    {
      "src": "server/src/vercel.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "server/assets/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/src/vercel.js"
    }
  ]
}
